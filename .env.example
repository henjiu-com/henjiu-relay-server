# Henjiu Relay 配置

# ============ 服务器 ============
HOST=0.0.0.0
PORT=8080

# ============ 用户配置 (JSON 数组) ============
# 支持多用户，每个用户有独立的 API Key
# USERS=[{"username":"admin","password":"123456","api_key":"random-key-1","role":"admin","enabled":true}]
# 或使用快捷方式:

# ============ 单用户快捷方式 ============
ADMIN_USERNAME=arno
ADMIN_PASSWORD=123456
# API_KEY 会自动生成

# ============ 实例配置 (JSON 数组) ============
# 每个实例可以配置独立的 authToken
# OPENCLAW_URLS=[{"id":"a","name":"Claw A","url":"http://192.168.1.10:18789","authToken":"instance-token-a"}]

# ============ 单实例快捷方式 ============
OPENCLAW_URL=http://192.168.1.100:18789
OPENCLAW_API_TOKEN=

# ============ 路由规则 ============
# OPENCLAW_ROUTES=[{"channel":"telegram","instance_id":"a"}]

# 默认实例
# DEFAULT_INSTANCE_ID=a
